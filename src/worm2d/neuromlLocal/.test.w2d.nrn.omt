target: LEMS_Worm2D.xml
engine: jNeuroML_NEURON

mep: .test.w2d.mep
experiments:
  state0:
    observables:
      spike times:
        file: 
          path: Worm2D.states.dat
          columns: [0,1]
          scaling: [1, 1]
        spike detection: 
          method: threshold
          threshold: -5
        tolerance: 0.00
  state3:
    observables:
      spike times:
        file: 
          path: Worm2D.states.dat
          columns: [0,19]
          scaling: [1, 1]
        spike detection: 
          method: threshold
          threshold: -12
        tolerance: 0.000504540867810237
  state54:
    observables:
      spike times:
        file: 
          path: Worm2D.states.dat
          columns: [0,28]
          scaling: [1, 1]
        spike detection: 
          method: threshold
          threshold: 3.35
        tolerance: 0.00

