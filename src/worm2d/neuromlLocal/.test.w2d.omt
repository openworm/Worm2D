target: LEMS_Worm2D.xml
engine: jNeuroML

mep: .test.w2d.mep
experiments:
  state0:
    observables:
      spike times:
        file: 
          path: Worm2D.states.dat
          columns: [0,1]
          scaling: [1, 1]
        spike detection: 
          method: threshold
          threshold: -5
        tolerance: 9.597850081593455e-05
  state3:
    observables:
      spike times:
        file: 
          path: Worm2D.states.dat
          columns: [0,19]
          scaling: [1, 1]
        spike detection: 
          method: threshold
          threshold: -12
        tolerance: 0.0007246639370991548
  state54:
    observables:
      spike times:
        file: 
          path: Worm2D.states.dat
          columns: [0,28]
          scaling: [1, 1]
        spike detection: 
          method: threshold
          threshold: 3.35
        tolerance: 0.0004413948075919599

