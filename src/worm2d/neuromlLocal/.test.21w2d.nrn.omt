target: LEMS_Worm2D.xml
engine: jNeuroML_NEURON

mep: .test.21w2d.mep
experiments:
  state0:
    observables:
      spike times:
        file: 
          path: Worm2D.states.dat
          columns: [0,1]
          scaling: [1, 1]
        spike detection: 
          method: threshold
          threshold: -5
        tolerance: 2.488676521837576e-05
