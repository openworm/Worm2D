<Lems>

<ComponentType name="cellW2Dosc"
    extends="baseCell"
    description="Oscillating Cell for Worm2D model">


    <Parameter name="amp" dimension="none" description="..."/>
    <Parameter name="freq" dimension="none" description="..."/>
    <Parameter name="phase" dimension="none" description="..."/>
    <Parameter name="timestep" dimension="none" description="..."/>
    

    <Constant name="TSCALE" dimension="time" value ="1s"/>
    <Constant name="MVOLT" dimension="voltage" value="1mV"/>
    <Constant name="PAMP" dimension="current" value="1pA"/>
    <Constant name="COND_SCALE" dimension="conductance" value="1nS"/>
    <DerivedParameter name="C" dimension="capacitance" value="TSCALE*COND_SCALE"/>
  
    <!--
    Defined in baseCellMembPotCap:
    <Parameter name="C" dimension="capacitance"/>
    -->
  

    <!-- Initial Conditions -->
    <!--<Parameter name="state0" dimension="none"/>-->


   

    <!-- <Exposure name="v" dimension="none"/> --> <!-- Already exposed from baseCellMembPotDL -->
    
    <Exposure name="state" dimension="none"/>
    <Exposure name="output" dimension="none"/>

    
    <Dynamics>
        
        <StateVariable name="v" dimension="voltage" description="Membrane potential state variable"/>
        <!--<StateVariable name="state" dimension="none" exposure="state"/>-->
        <DerivedVariable name="state" dimension="none" exposure="state" value="v/MVOLT" />   
        <DerivedVariable name="output" dimension="none" exposure="output" value="amp*sin(6.2831853*freq*(state + timestep) + phase)" />

        <!--<TimeDerivative variable="v" value="timestep * PAMP / C" />-->
        <TimeDerivative variable="v" value="PAMP / C" />

        <OnStart>
            <!--<StateAssignment variable="v" value="state0*MVOLT"/>-->
            <StateAssignment variable="v" value="0"/>
        </OnStart>
        
    

    </Dynamics>
    
</ComponentType>

</Lems>
    
